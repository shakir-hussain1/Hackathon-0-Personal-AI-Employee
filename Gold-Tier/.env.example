# ── Vault ─────────────────────────────────────────────────────────────────────
# VAULT_PATH=C:\path\to\AI_Employee_Vault

# ── DRY RUN (safety) ──────────────────────────────────────────────────────────
# true = no real external actions (emails, tweets, posts, invoices)
# ALWAYS start with DRY_RUN=true, switch to false only when ready
DRY_RUN=true

# ── Feature toggles ───────────────────────────────────────────────────────────
ENABLE_ODOO=false
ENABLE_FACEBOOK=false
ENABLE_INSTAGRAM=false
ENABLE_TWITTER=false
ENABLE_WEEKLY_AUDIT=true
ENABLE_RALPH_LOOP=true
ENABLE_SILVER_INTEGRATION=true
ENABLE_WATCHDOG_GOLD=true
ENABLE_WATCHDOG_SILVER=true

# ── Odoo Community (Docker) ───────────────────────────────────────────────────
# Start: docker-compose -f Gold-Tier/docker/docker-compose.odoo.yml up -d
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USER=admin
ODOO_PASSWORD=admin

# ── Facebook & Instagram (Meta Graph API) ─────────────────────────────────────
# 1. Create app at https://developers.facebook.com/
# 2. Add Facebook Login + Instagram Graph API products
# 3. Get a permanent Page Access Token
# 4. Enable: pages_manage_posts, instagram_basic, instagram_content_publish
FB_PAGE_ID=your_facebook_page_id
FB_PAGE_ACCESS_TOKEN=your_page_access_token
IG_ACCOUNT_ID=your_instagram_business_account_id

# ── Twitter / X (API v2) ──────────────────────────────────────────────────────
# 1. Create app at https://developer.twitter.com/
# 2. Enable Read + Write permissions (in app settings)
# 3. Generate Access Token + Secret from app dashboard
TWITTER_BEARER_TOKEN=your_bearer_token
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_token_secret

# ── Anthropic API (inherited from Silver) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
REASONING_MODEL=claude-opus-4-6

# ── Scheduling ────────────────────────────────────────────────────────────────
SOCIAL_SUMMARY_INTERVAL_HOURS=6
WEEKLY_AUDIT_DAY=sunday
WEEKLY_AUDIT_TIME=20:00
WATCHDOG_INTERVAL_SECONDS=60

# ── Ralph Wiggum Loop ─────────────────────────────────────────────────────────
RALPH_MAX_ITERATIONS=10

# ── Audit Logging ─────────────────────────────────────────────────────────────
LOG_RETENTION_DAYS=90

# ── Silver-Tier integration (re-uses Silver .env) ─────────────────────────────
# Silver-Tier reads its own .env — nothing to set here.
# Just ensure Silver-Tier/.env exists and is configured.
