# ── Vault ─────────────────────────────────────────────────────────────────────
# Override if vault is not at the default location relative to Silver-Tier root
# VAULT_PATH=C:\path\to\AI_Employee_Vault

# ── Google OAuth (Gmail + Calendar) ──────────────────────────────────────────
# Download credentials.json from Google Cloud Console and place in Silver-Tier/
# After first run, tokens are cached automatically:
#   .gmail_token.json       — Gmail read/modify
#   .gmail_send_token.json  — Gmail send
#   .calendar_token.json    — Calendar read

# ── Scheduling ────────────────────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=15
CALENDAR_INTERVAL_MINUTES=60
CALENDAR_LOOKAHEAD_HOURS=24
DAILY_REPORT_TIME=18:00

# ── Feature toggles ───────────────────────────────────────────────────────────
ENABLE_GMAIL=true
ENABLE_CALENDAR=true
ENABLE_EMAIL_SENDER=true
ENABLE_LINKEDIN=true

# ── Anthropic API (Reasoning Loop → Plan.md) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Model to use for reasoning loop:
REASONING_MODEL=claude-opus-4-6

# ── LinkedIn API ──────────────────────────────────────────────────────────────
# 1. Create a LinkedIn Developer App: https://developer.linkedin.com/
# 2. Request scope: w_member_social
# 3. Complete OAuth 2.0 flow to get an access token
# 4. Find your Person URN: GET https://api.linkedin.com/v2/me
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token-here
LINKEDIN_AUTHOR_URN=urn:li:person:YOUR_PERSON_ID
LINKEDIN_CHECK_INTERVAL_MINUTES=60

# ── WhatsApp Watcher (Playwright) ─────────────────────────────────────────────
# Set ENABLE_WHATSAPP=true and run once with WHATSAPP_HEADLESS=false to scan QR code.
# After login, session is saved to .whatsapp_session/ and headless mode works.
ENABLE_WHATSAPP=false
WHATSAPP_HEADLESS=true
# WHATSAPP_SESSION_PATH=C:\path\to\.whatsapp_session   # override if needed
WHATSAPP_INTERVAL_SECONDS=60
